# ═══════════════════════════════════════════════════════════════
# GATEWAY CONTROL - DOCKER DEPLOYMENT
# ═══════════════════════════════════════════════════════════════

# ─── REQUIRED ────────────────────────────────────────────────────────
# Generate a secure random key. Use: openssl rand -hex 32
# This key protects your admin dashboard - keep it secret!
ADMIN_API_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_NOW

# ─── OPTIONAL (Telegram Alerts) ────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (send /start to @userinfobot to get it)
TELEGRAM_CHAT_ID=

# ─── OPTIONAL (TrustPositif API) ────────────────────────────────────────
# Get API key from trustpositif.id for higher rate limits
# Without this: 100 checks/day limit
# With this: higher limits (check their API docs)
TP_API_KEY=
